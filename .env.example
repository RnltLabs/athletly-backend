# AgenticSports Environment Variables
# Copy this file to .env and fill in your values.

# LLM Keys (at least one required)
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Model override (default: gemini/gemini-2.5-flash)
# AGENTICSPORTS_MODEL=claude-sonnet-4-20250514

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# User ID for Supabase mode (set to a Supabase auth.users UUID to enable DB persistence)
# Leave empty to use legacy file-based storage.
AGENTICSPORTS_USER_ID=

# Optional
BRAVE_SEARCH_API_KEY=
